rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /shipments/{id} { allow read: if true; allow write: if request.auth != null; }
    match /disruptions/{id} { allow read: if true; allow write: if false; }
    match /impactReports/{id} { allow read: if true; allow write: if false; }
    match /resolutions/{id} {
      allow read: if true; allow write: if false;
      match /options/{optId} { allow read: if true; allow write: if false; }
    }
    match /suppliers/{id} { allow read: if true; allow write: if false; }
    match /errors/{id} { allow read: if false; allow write: if false; }
  }
}
